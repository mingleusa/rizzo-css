---
import BlocksLayout from '../../layouts/BlocksLayout.astro';
import Card from '../../components/astro/Card.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import FrameworkCodeTabs from '../../components/FrameworkCodeTabs.astro';
import { LANDING_HERO_SNIPPETS } from '../../config/blockCodeSnippets';
---

<BlocksLayout
	title="Landing hero"
	description="Marketing hero section with headline, subtitle, and primary CTAs. Uses Rizzo typography and button components."
	documentTitle="Landing hero — Blocks — Rizzo CSS"
>
	<section>
		<p>This block is a <strong>landing hero</strong>: centered headline, supporting text, and call-to-action buttons. Use it as the top of a marketing or product page. Same structure when you scaffold with <code>npx rizzo-css init --template landing</code>.</p>
	</section>

	<section>
		<h2 id="preview">Preview</h2>
		<p class="docs-dim">Hero section using design tokens and button classes.</p>
		<div class="block-preview-wrapper block-preview-wrapper--hero">
			<header class="landing-hero">
				<h1 class="landing-hero__title">Build something great</h1>
				<p class="landing-hero__subtitle">A themeable, accessible design system. Same CSS across Vanilla, Astro, Svelte, React, and Vue — no runtime lock-in.</p>
				<div class="landing-hero__ctas">
					<a href="/docs/getting-started" class="btn btn-primary">Get started</a>
					<a href="/docs/components" class="btn btn-outline">View components</a>
				</div>
			</header>
		</div>
	</section>

	<section>
		<h2 id="usage">Usage</h2>
		<p>Copy the snippet for your framework. Same BEM classes and structure work everywhere.</p>
		<FrameworkCodeTabs
			astro={LANDING_HERO_SNIPPETS.astro}
			svelte={LANDING_HERO_SNIPPETS.svelte}
			react={LANDING_HERO_SNIPPETS.react}
			vue={LANDING_HERO_SNIPPETS.vue}
			vanilla={LANDING_HERO_SNIPPETS.vanilla}
			defaultTab="astro"
		/>
	</section>

	<section>
		<h2 id="scaffold">Get this block via CLI</h2>
		<p>Scaffold a new project with the Landing template:</p>
		<CodeBlock code="npx rizzo-css init --framework astro --template landing --yes" language="bash" />
		<p>Or add to an existing project:</p>
		<CodeBlock code="npx rizzo-css add --framework astro --template landing" language="bash" />
	</section>

	<section>
		<h2>Components used</h2>
		<ul>
			<li>Rizzo <strong>typography</strong> and <strong>spacing</strong> tokens</li>
			<li><a href="/docs/components/button">Button</a> classes (<code>btn</code>, <code>btn-primary</code>, <code>btn-outline</code>)</li>
		</ul>
	</section>
</BlocksLayout>

<!-- Block styles: pages.css (landing-hero, block-preview-wrapper, docs-dim) -->

---
import DocsLayout from '../../../../layouts/DocsLayout.astro';
import CodeBlock from '../../../../components/CodeBlock.astro';
import AddComponentTabs from '../../../../components/AddComponentTabs.astro';
import { getVanillaCodeSnippet } from '../../../../config/vanillaCodeSnippets';
---

<DocsLayout title="Command — Vanilla" description="Command palette (e.g. ⌘K) with vanilla HTML and Rizzo CSS. Add JS for open/close and search.">
  <section>
    <h2>Command</h2>
    <p>Command palette: overlay + dialog with search and list. Classes: <code>command-root</code>, <code>command__overlay</code>, <code>command__dialog</code>, <code>command__search</code>, <code>command__list</code>, <code>command__item</code>. Add JavaScript to toggle visibility on trigger click and ⌘K, and to filter items by search input.</p>
    <AddComponentTabs componentName="Command" />
    <h3>HTML</h3>
    <CodeBlock code={getVanillaCodeSnippet('command')} language="html" />
    <p><strong>Other frameworks:</strong> <a href="/docs/components/command">Astro</a> · <a href="/docs/svelte/components/command">Svelte</a> · <a href="/docs/vue/components/command">Vue</a> · <a href="/docs/react/components/command">React</a></p>
  </section>
</DocsLayout>

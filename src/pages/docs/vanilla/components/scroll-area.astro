---
import DocsLayout from '../../../../layouts/DocsLayout.astro';
import CodeBlock from '../../../../components/CodeBlock.astro';
import AddComponentTabs from '../../../../components/AddComponentTabs.astro';

const tags = Array.from({ length: 20 }, (_, i) => `v1.2.0-beta.${20 - i}`);
const copyableHtml = `<div class="scroll-area" style="height: 18rem; width: 12rem;">
  <div class="scroll-area__viewport" tabindex="0">
    <div style="padding: var(--spacing-4);">
      <h4 style="margin: 0 0 var(--spacing-4) 0; font-size: var(--font-size-sm); font-weight: 600;">Tags</h4>
      <div style="font-size: var(--font-size-sm); margin-bottom: var(--spacing-2);">v1.2.0-beta.20</div>
      <div style="font-size: var(--font-size-sm); margin-bottom: var(--spacing-2);">v1.2.0-beta.19</div>
      <!-- ... -->
    </div>
  </div>
</div>`;
---

<DocsLayout title="Scroll Area — Vanilla" description="Scrollable area with themed scrollbar. Ensure Rizzo CSS is loaded.">
  <section>
    <h2>Scroll Area</h2>
    <p>Give the wrapper a fixed height (or width for horizontal). Use <code>scroll-area</code> and <code>scroll-area__viewport</code>. Add <code>scroll-area--horizontal</code> for horizontal scrolling.</p>
    <AddComponentTabs componentName="ScrollArea" />
    <div class="example">
      <div class="example-title">Live example</div>
      <div class="scroll-area" style="height: 18rem; width: 12rem; border-radius: var(--radius-md); border: var(--border-width) solid var(--border);">
        <div class="scroll-area__viewport" tabindex="0">
          <div style="padding: var(--spacing-4);">
            <h4 style="margin: 0 0 var(--spacing-4) 0; font-size: var(--font-size-sm); font-weight: 600;">Tags</h4>
            {tags.map((tag) => (
              <div style="font-size: var(--font-size-sm); margin-bottom: var(--spacing-2);">{tag}</div>
            ))}
          </div>
        </div>
      </div>
    </div>
    <h3>HTML</h3>
    <CodeBlock code={copyableHtml} language="html" />
    <p><strong>Other frameworks:</strong> <a href="/docs/components/scroll-area">Astro</a> · <a href="/docs/svelte/components/scroll-area">Svelte</a> · <a href="/docs/vue/components/scroll-area">Vue</a> · <a href="/docs/react/components/scroll-area">React</a></p>
  </section>
</DocsLayout>

<style>
  .example { margin: var(--spacing-6) 0; padding: var(--spacing-4); background: var(--background-alt); border: 1px solid var(--border); border-radius: var(--radius-lg); }
  .example-title { font-size: var(--font-size-sm); font-weight: var(--font-weight-medium); color: var(--text-dim); margin-bottom: var(--spacing-3); text-transform: uppercase; letter-spacing: var(--letter-spacing-wider); }
</style>

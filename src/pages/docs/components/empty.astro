---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import Empty from '../../../components/astro/Empty.astro';
import AddComponentTabs from '../../../components/AddComponentTabs.astro';
import FrameworkCodeTabs from '../../../components/FrameworkCodeTabs.astro';

import { getReactCodeSnippet } from '../../../config/reactCodeSnippets';
import { getVueCodeSnippet } from '../../../config/vueCodeSnippets';
const componentSlug = 'empty';
const reactCode = getReactCodeSnippet(componentSlug);
const vueCode = getVueCodeSnippet(componentSlug);
---

<DocsLayout title="Empty" description="Empty state with optional icon, title, description, and action. Matches shadcn-svelte Empty.">
	<section>
		<h2>Empty</h2>
		<p>Use for no results, empty lists, or empty search. Slots: <code>icon</code>, default (none), <code>action</code>.</p>
		<AddComponentTabs componentName="Empty" />
		<div class="example">
			<div class="example-title">Live Example</div>
			<Empty title="No items yet" description="Get started by adding your first item.">
				<button type="button" slot="action" class="btn btn-primary">Add item</button>
			</Empty>
		</div>
		<h3>Usage</h3>
		<FrameworkCodeTabs
			astro={`---
import Empty from '../components/astro/Empty.astro';
---

<Empty title="No items yet" description="Get started by adding your first item.">
  <button type="button" slot="action" class="btn btn-primary">Add item</button>
</Empty>`}
			svelte={`<script>
  import { Empty } from '$lib/rizzo';
</script>

<Empty title="No items yet" description="Get started by adding your first item.">
  <button type="button" class="btn btn-primary">Add item</button>
</Empty>`}
			react={reactCode}
			vue={vueCode}
			vanilla={`<!-- Rizzo CSS. No script needed. BEM: empty, empty__icon, empty__title, empty__description, empty__action. -->
<div class="empty">
  <h3 class="empty__title">No items yet</h3>
  <p class="empty__description">Get started by adding your first item.</p>
  <div class="empty__action"><button type="button" class="btn btn-primary">Add item</button></div>
</div>`}
		/>
		<p><strong>Other frameworks:</strong> <a href="/docs/vanilla/components/empty">Vanilla</a> · <a href="/docs/svelte/components/empty">Svelte</a> · <a href="/docs/vue/components/empty">Vue</a> · <a href="/docs/react/components/empty">React</a></p>
	</section>
</DocsLayout>

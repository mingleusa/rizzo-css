---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import DashboardComponent from '../../../components/astro/Dashboard.astro';
import Card from '../../../components/astro/Card.astro';
import AddComponentTabs from '../../../components/AddComponentTabs.astro';
import FrameworkCodeTabs from '../../../components/FrameworkCodeTabs.astro';

import { getReactCodeSnippet } from '../../../config/reactCodeSnippets';
import { getVueCodeSnippet } from '../../../config/vueCodeSnippets';
const componentSlug = 'dashboard';
const reactCode = getReactCodeSnippet(componentSlug);
const vueCode = getVueCodeSnippet(componentSlug);
---

<DocsLayout title="Dashboard Component — Astro" description="Layout component with sidebar and main content area for app dashboards. Uses Rizzo tokens and BEM classes.">
	<section>
		<h2>Dashboard Component</h2>
		<p>The Dashboard component provides a two-column layout: a sidebar (for navigation) and a main content area. It uses Rizzo design tokens and BEM classes (<code>dashboard</code>, <code>dashboard__sidebar</code>, <code>dashboard__main</code>, <code>dashboard__nav</code>, <code>dashboard__nav-link</code>). On small screens the layout stacks vertically.</p>
		<AddComponentTabs componentName="Dashboard" />
	</section>

	<section>
		<h2>Basic usage</h2>
		<p>Use the default sidebar (Dashboard, Items, Settings) or pass your own nav via the <code>sidebar</code> slot (Astro) or <code>sidebar</code> snippet (Svelte).</p>

		<div class="example">
			<div class="example-title">Live example</div>
			<div class="dashboard-demo-wrap">
				<DashboardComponent sidebarLabel="Dashboard navigation">
					<nav slot="sidebar" class="dashboard__nav">
						<a href="/docs/components/dashboard" class="dashboard__nav-link dashboard__nav-link--active" aria-current="page">Dashboard</a>
						<a href="#" class="dashboard__nav-link">Items</a>
						<a href="#" class="dashboard__nav-link">Settings</a>
					</nav>
					<div class="dashboard-page">
						<header class="dashboard-page__header">
							<h1 class="dashboard-page__title">Dashboard</h1>
							<p class="dashboard-page__subtitle">Overview. Same structure as the <a href="/blocks/dashboard-01">Dashboard block</a>.</p>
						</header>
						<section class="dashboard-page__stats" aria-labelledby="demo-stats-heading">
							<h2 id="demo-stats-heading" class="sr-only">Key metrics</h2>
							<div class="dashboard-page__stats-grid">
								<Card class="dashboard-page__stat">
									<div class="card__body">
										<span class="card__label">Total users</span>
										<span class="card__value">1,234</span>
									</div>
								</Card>
								<Card class="dashboard-page__stat">
									<div class="card__body">
										<span class="card__label">Revenue</span>
										<span class="card__value">$12,345</span>
									</div>
								</Card>
								<Card class="dashboard-page__stat">
									<div class="card__body">
										<span class="card__label">Active</span>
										<span class="card__value">89%</span>
									</div>
								</Card>
							</div>
						</section>
						<section class="dashboard-page__table" aria-labelledby="demo-table-heading">
							<h2 id="demo-table-heading" class="dashboard-page__section-title">Recent activity</h2>
							<div class="table-wrapper">
								<table class="table">
									<caption class="sr-only">Recent activity list</caption>
									<thead>
										<tr class="table__row">
											<th scope="col" class="table__cell table__cell--header">Name</th>
											<th scope="col" class="table__cell table__cell--header">Status</th>
											<th scope="col" class="table__cell table__cell--header">Date</th>
										</tr>
									</thead>
									<tbody>
										<tr class="table__row">
											<td class="table__cell">Item one</td>
											<td class="table__cell"><span class="badge badge--success">Done</span></td>
											<td class="table__cell">Today</td>
										</tr>
										<tr class="table__row">
											<td class="table__cell">Item two</td>
											<td class="table__cell"><span class="badge badge--warning">Pending</span></td>
											<td class="table__cell">Yesterday</td>
										</tr>
										<tr class="table__row">
											<td class="table__cell">Item three</td>
											<td class="table__cell"><span class="badge badge--error">Failed</span></td>
											<td class="table__cell">Jan 15</td>
										</tr>
									</tbody>
								</table>
							</div>
						</section>
					</div>
				</DashboardComponent>
			</div>
		</div>

		<h3>Usage</h3>
		<FrameworkCodeTabs
			astro={`---
import Dashboard from '../components/astro/Dashboard.astro';
---

<Dashboard sidebarLabel="App navigation">
  <nav slot="sidebar" class="dashboard__nav">
    <a href="/dashboard" class="dashboard__nav-link dashboard__nav-link--active" aria-current="page">Dashboard</a>
    <a href="/items" class="dashboard__nav-link">Items</a>
    <a href="/settings" class="dashboard__nav-link">Settings</a>
  </nav>
  <main>
    <h1>Dashboard</h1>
    <p>Your content here.</p>
  </main>
</Dashboard>`}
			svelte={`<script>
  import { Dashboard } from '$lib/rizzo';
</script>

<Dashboard sidebarLabel="App navigation">
  {#snippet sidebar()}
    <nav class="dashboard__nav">
      <a href="/dashboard" class="dashboard__nav-link dashboard__nav-link--active" aria-current="page">Dashboard</a>
      <a href="/items" class="dashboard__nav-link">Items</a>
      <a href="/settings" class="dashboard__nav-link">Settings</a>
    </nav>
  {/snippet}
  <h1>Dashboard</h1>
  <p>Your content here.</p>
</Dashboard>`}
			react={reactCode}
			vue={vueCode}
			vanilla={`<!-- Rizzo CSS. No script needed. -->
<div class="dashboard">
  <aside class="dashboard__sidebar" aria-label="App navigation">
    <nav class="dashboard__nav">
      <a href="/dashboard" class="dashboard__nav-link dashboard__nav-link--active" aria-current="page">Dashboard</a>
      <a href="/items" class="dashboard__nav-link">Items</a>
      <a href="/settings" class="dashboard__nav-link">Settings</a>
    </nav>
  </aside>
  <main id="main-content" class="dashboard__main">
    <h1>Dashboard</h1>
    <p>Your content here.</p>
  </main>
</div>`}
		/>
	</section>

	<section>
		<h2>Props (Astro)</h2>
		<ul>
			<li><code>sidebarLabel</code> — Aria-label for the sidebar (default: <code>"Dashboard navigation"</code>).</li>
			<li><code>class</code> — Optional class on the root <code>.dashboard</code> element.</li>
		</ul>
		<p>Slot <code>sidebar</code>: optional. If provided, replaces the default nav links. Default slot: main content.</p>
	</section>

	<section>
		<h2>BEM classes</h2>
		<ul>
			<li><code>dashboard</code> — Root flex container (column on mobile).</li>
			<li><code>dashboard__sidebar</code> — Sidebar column.</li>
			<li><code>dashboard__nav</code> — Nav container inside sidebar.</li>
			<li><code>dashboard__nav-link</code> — Nav link; use <code>dashboard__nav-link--active</code> for current page.</li>
			<li><code>dashboard__main</code> — Main content area.</li>
		</ul>
		<p><strong>Other frameworks:</strong> <a href="/docs/vanilla/components/dashboard">Vanilla</a> · <a href="/docs/svelte/components/dashboard">Svelte</a> · <a href="/docs/vue/components/dashboard">Vue</a> · <a href="/docs/react/components/dashboard">React</a></p>
	</section>

	<section>
		<h2>Related</h2>
		<p>See the <a href="/blocks/dashboard-01">Dashboard with sidebar</a> block for a full example with stat cards and a table.</p>
	</section>
</DocsLayout>

<style>
	.dashboard-demo-wrap {
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		overflow: hidden;
		min-height: 14rem;
	}
	.dashboard-demo-wrap :global(.dashboard) {
		min-height: 14rem;
	}
</style>

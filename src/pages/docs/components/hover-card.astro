---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import HoverCard from '../../../components/HoverCard.astro';
import AddComponentTabs from '../../../components/AddComponentTabs.astro';
import FrameworkCodeTabs from '../../../components/FrameworkCodeTabs.astro';

import { getReactCodeSnippet } from '../../../config/reactCodeSnippets';
import { getVueCodeSnippet } from '../../../config/vueCodeSnippets';
const componentSlug = 'hover-card';
const reactCode = getReactCodeSnippet(componentSlug);
const vueCode = getVueCodeSnippet(componentSlug);
---

<DocsLayout title="Hover Card" description="Floating panel that opens on hover. Matches shadcn-svelte Hover Card.">
	<section>
		<h2>Hover Card</h2>
		<p>Trigger must have <code>data-hover-card-trigger</code>. Content appears on hover with optional open/close delay.</p>
		<AddComponentTabs componentName="HoverCard" />
		<div class="example">
			<div class="example-title">Live Example</div>
			<HoverCard>
				<span slot="trigger" data-hover-card-trigger style="cursor: pointer; text-decoration: underline;">Hover me</span>
				<div style="min-width: 16rem;">
					<p style="margin: 0; font-size: var(--font-size-sm);">SvelteKit — Web development, streamlined.</p>
				</div>
			</HoverCard>
		</div>
		<h3>Usage</h3>
		<FrameworkCodeTabs
			astro={`---
import HoverCard from '../components/rizzo/HoverCard.astro';
---

<HoverCard>
  <span slot="trigger" data-hover-card-trigger style="cursor: pointer;">Hover me</span>
  <div style="min-width: 16rem;"><p>Card content here.</p></div>
</HoverCard>`}
			svelte={`<script>
  import { HoverCard } from '$lib/rizzo';
</script>

<HoverCard>
  <span data-hover-card-trigger style="cursor: pointer;">Hover me</span>
  <div style="min-width: 16rem;"><p>Card content here.</p></div>
</HoverCard>`}
			react={reactCode}
			vue={vueCode}
			vanilla={`<!-- Rizzo CSS + hover-card script from package/vanilla docs. data-hover-card-trigger on trigger; content in hover-card__content. Opens on hover. -->`}
		/>
	</section>
</DocsLayout>

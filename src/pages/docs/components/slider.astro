---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import Slider from '../../../components/Slider.astro';
import AddComponentTabs from '../../../components/AddComponentTabs.astro';
import FrameworkCodeTabs from '../../../components/FrameworkCodeTabs.astro';

import { getReactCodeSnippet } from '../../../config/reactCodeSnippets';
import { getVueCodeSnippet } from '../../../config/vueCodeSnippets';
const componentSlug = 'slider';
const reactCode = getReactCodeSnippet(componentSlug);
const vueCode = getVueCodeSnippet(componentSlug);
---

<DocsLayout title="Slider" description="Range slider input with themed track and fill. Matches shadcn-svelte Slider.">
	<section>
		<h2>Slider</h2>
		<p>Accessible range input with visible track and fill. Props: <code>min</code>, <code>max</code>, <code>step</code>, <code>value</code>, <code>disabled</code>.</p>
		<AddComponentTabs componentName="Slider" />
		<div class="example">
			<div class="example-title">Live Example</div>
			<Slider ariaLabel="Volume" min={0} max={100} value={50} />
		</div>
		<h3>Usage</h3>
		<FrameworkCodeTabs
			astro={`---
import Slider from '../components/rizzo/Slider.astro';
---

<Slider ariaLabel="Volume" min={0} max={100} value={50} />`}
			svelte={`<script>
  import { Slider } from '$lib/rizzo';
</script>

<Slider ariaLabel="Volume" min={0} max={100} value={50} />`}
			react={reactCode}
			vue={vueCode}
			vanilla={`<!-- Rizzo CSS. Use BEM: slider, slider__track, slider__fill; input type="range" inside. -->
<div class="slider" data-slider>
  <div class="slider__track">
    <div class="slider__fill" style="--slider-fill: 50%;"></div>
    <input type="range" min="0" max="100" value="50" aria-label="Volume" class="slider__input" />
  </div>
</div>`}
		/>
	</section>
</DocsLayout>

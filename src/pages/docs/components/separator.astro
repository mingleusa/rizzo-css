---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import Separator from '../../../components/astro/Separator.astro';
import AddComponentTabs from '../../../components/AddComponentTabs.astro';
import FrameworkCodeTabs from '../../../components/FrameworkCodeTabs.astro';

import { getReactCodeSnippet } from '../../../config/reactCodeSnippets';
import { getVueCodeSnippet } from '../../../config/vueCodeSnippets';
const componentSlug = 'separator';
const reactCode = getReactCodeSnippet(componentSlug);
const vueCode = getVueCodeSnippet(componentSlug);
---

<DocsLayout title="Separator" description="Thin separator line (horizontal or vertical). Matches shadcn-svelte Separator.">
	<section>
		<h2>Separator</h2>
		<p>Minimal line; use <a href="/docs/components/divider">Divider</a> when you need a label (e.g. "OR").</p>
		<AddComponentTabs componentName="Separator" />
		<div class="example">
			<div class="example-title">Live Example</div>
			<div>Above</div>
			<Separator />
			<div>Below</div>
		</div>
		<h3>Usage</h3>
		<FrameworkCodeTabs
			astro={`---
import Separator from '../components/astro/Separator.astro';
---

<div>Above</div>
<Separator />
<div>Below</div>`}
			svelte={`<script>
  import { Separator } from '$lib/rizzo';
</script>

<div>Above</div>
<Separator />
<div>Below</div>`}
			react={reactCode}
			vue={vueCode}
			vanilla={`<!-- Rizzo CSS. No script needed. -->
<div>Above</div>
<div class="separator separator--horizontal" role="separator" aria-orientation="horizontal"></div>
<div>Below</div>`}
		/>
		<p><strong>Other frameworks:</strong> <a href="/docs/vanilla/components/separator">Vanilla</a> · <a href="/docs/svelte/components/separator">Svelte</a> · <a href="/docs/vue/components/separator">Vue</a> · <a href="/docs/react/components/separator">React</a></p>
	</section>
</DocsLayout>

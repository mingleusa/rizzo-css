---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import ButtonGroup from '../../../components/ButtonGroup.astro';
import AddComponentTabs from '../../../components/AddComponentTabs.astro';
import FrameworkCodeTabs from '../../../components/FrameworkCodeTabs.astro';

import { getReactCodeSnippet } from '../../../config/reactCodeSnippets';
import { getVueCodeSnippet } from '../../../config/vueCodeSnippets';
const componentSlug = 'button-group';
const reactCode = getReactCodeSnippet(componentSlug);
const vueCode = getVueCodeSnippet(componentSlug);
---

<DocsLayout title="Button Group" description="Group of buttons attached together. Matches shadcn-svelte Button Group.">
	<section>
		<h2>Button Group</h2>
		<p>Buttons with no gap; first/last get rounded corners. Use <code>orientation="vertical"</code> for a vertical group.</p>
		<AddComponentTabs componentName="ButtonGroup" />
		<div class="example">
			<div class="example-title">Live Example</div>
			<ButtonGroup>
				<button type="button" class="btn">One</button>
				<button type="button" class="btn">Two</button>
				<button type="button" class="btn">Three</button>
			</ButtonGroup>
		</div>
		<h3>Usage</h3>
		<FrameworkCodeTabs
			astro={`---
import ButtonGroup from '../components/rizzo/ButtonGroup.astro';
---

<ButtonGroup>
  <button type="button" class="btn">One</button>
  <button type="button" class="btn">Two</button>
  <button type="button" class="btn">Three</button>
</ButtonGroup>`}
			svelte={`<script>
  import { ButtonGroup } from '$lib/rizzo';
</script>

<ButtonGroup>
  <button type="button" class="btn">One</button>
  <button type="button" class="btn">Two</button>
  <button type="button" class="btn">Three</button>
</ButtonGroup>`}
			react={reactCode}
			vue={vueCode}
			vanilla={`<!-- Rizzo CSS. No script needed. -->
<div class="button-group" role="group">
  <button type="button" class="btn">One</button>
  <button type="button" class="btn">Two</button>
  <button type="button" class="btn">Three</button>
</div>`}
		/>
	</section>
</DocsLayout>

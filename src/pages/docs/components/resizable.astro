---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import ResizablePaneGroup from '../../../components/astro/ResizablePaneGroup.astro';
import ResizablePane from '../../../components/astro/ResizablePane.astro';
import ResizableHandle from '../../../components/astro/ResizableHandle.astro';
import AddComponentTabs from '../../../components/AddComponentTabs.astro';
import FrameworkCodeTabs from '../../../components/FrameworkCodeTabs.astro';

import { getReactCodeSnippet } from '../../../config/reactCodeSnippets';
import { getVueCodeSnippet } from '../../../config/vueCodeSnippets';
const componentSlug = 'resizable';
const reactCode = getReactCodeSnippet(componentSlug);
const vueCode = getVueCodeSnippet(componentSlug);
---

<DocsLayout title="Resizable" description="Resizable panel groups. Matches shadcn-svelte Resizable.">
	<section>
		<h2>Resizable</h2>
		<p>Use <code>ResizablePaneGroup</code> with <code>direction="horizontal"</code> or <code>vertical</code>, <code>ResizablePane</code> (defaultSize 0–100), and <code>ResizableHandle</code> between panes. Drag the handle to resize.</p>
		<AddComponentTabs componentName="Resizable" />
		<h3>Horizontal</h3>
		<div class="example">
			<div class="example-title">Live Example</div>
			<ResizablePaneGroup direction="horizontal" class="max-w-md rounded-lg border" style="max-width: 28rem; border-radius: var(--radius-lg); border: var(--border-width) solid var(--border);">
				<ResizablePane defaultSize={50}>
					<div style="display: flex; height: 200px; align-items: center; justify-content: center; padding: var(--spacing-6);"><span style="font-weight: 600;">One</span></div>
				</ResizablePane>
				<ResizableHandle />
				<ResizablePane defaultSize={50}>
					<div style="display: flex; height: 200px; align-items: center; justify-content: center; padding: var(--spacing-6);"><span style="font-weight: 600;">Two</span></div>
				</ResizablePane>
			</ResizablePaneGroup>
		</div>
		<h3>Vertical</h3>
		<div class="example">
			<ResizablePaneGroup direction="vertical" class="min-h-[200px] max-w-md rounded-lg border" style="min-height: 200px; max-width: 28rem; border-radius: var(--radius-lg); border: var(--border-width) solid var(--border);">
				<ResizablePane defaultSize={25}>
					<div style="display: flex; height: 100%; align-items: center; justify-content: center; padding: var(--spacing-6);"><span style="font-weight: 600;">Header</span></div>
				</ResizablePane>
				<ResizableHandle />
				<ResizablePane defaultSize={75}>
					<div style="display: flex; height: 100%; align-items: center; justify-content: center; padding: var(--spacing-6);"><span style="font-weight: 600;">Content</span></div>
				</ResizablePane>
			</ResizablePaneGroup>
		</div>
		<h3>Usage</h3>
		<FrameworkCodeTabs
			astro={`---
import ResizablePaneGroup from '../components/astro/ResizablePaneGroup.astro';
import ResizablePane from '../components/astro/ResizablePane.astro';
import ResizableHandle from '../components/astro/ResizableHandle.astro';
---

<ResizablePaneGroup direction="horizontal" style="max-width: 28rem; height: 200px;">
  <ResizablePane defaultSize={50}><div>One</div></ResizablePane>
  <ResizableHandle />
  <ResizablePane defaultSize={50}><div>Two</div></ResizablePane>
</ResizablePaneGroup>`}
			svelte={`<script>
  import { ResizablePaneGroup, ResizablePane, ResizableHandle } from '$lib/rizzo';
</script>

<ResizablePaneGroup direction="horizontal" style="max-width: 28rem; height: 200px;">
  <ResizablePane defaultSize={50}><div>One</div></ResizablePane>
  <ResizableHandle />
  <ResizablePane defaultSize={50}><div>Two</div></ResizablePane>
</ResizablePaneGroup>`}
			react={reactCode}
			vue={vueCode}
			vanilla={`<!-- Rizzo CSS + resizable script from package/vanilla docs. BEM: resizable-pane-group, resizable-pane, resizable-handle. -->
<div class="resizable-pane-group resizable-pane-group--horizontal" data-resizable style="max-width: 28rem; height: 200px;">
  <div class="resizable-pane" style="flex: 0 0 50%;">One</div>
  <div class="resizable-handle" data-resizable-handle aria-valuenow="50"></div>
  <div class="resizable-pane" style="flex: 0 0 50%;">Two</div>
</div>`}
		/>
		<p><strong>Other frameworks:</strong> <a href="/docs/vanilla/components/resizable">Vanilla</a> · <a href="/docs/svelte/components/resizable">Svelte</a> · <a href="/docs/vue/components/resizable">Vue</a> · <a href="/docs/react/components/resizable">React</a></p>
	</section>
</DocsLayout>

---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import Popover from '../../../components/Popover.astro';
import AddComponentTabs from '../../../components/AddComponentTabs.astro';
import FrameworkCodeTabs from '../../../components/FrameworkCodeTabs.astro';

import { getReactCodeSnippet } from '../../../config/reactCodeSnippets';
import { getVueCodeSnippet } from '../../../config/vueCodeSnippets';
const componentSlug = 'popover';
const reactCode = getReactCodeSnippet(componentSlug);
const vueCode = getVueCodeSnippet(componentSlug);
---

<DocsLayout title="Popover" description="Floating panel triggered by a button. Matches shadcn-svelte Popover.">
	<section>
		<h2>Popover</h2>
		<p>Trigger must have <code>data-popover-trigger</code>. Content appears below; click outside or Escape to close.</p>
		<AddComponentTabs componentName="Popover" />
		<div class="example">
			<div class="example-title">Live Example</div>
			<Popover>
				<button type="button" class="btn" slot="trigger" data-popover-trigger>Open popover</button>
				<p style="margin:0;">Popover content here.</p>
			</Popover>
		</div>
		<h3>Usage</h3>
		<FrameworkCodeTabs
			astro={`---
import Popover from '../components/rizzo/Popover.astro';
---

<Popover>
  <button type="button" class="btn" slot="trigger" data-popover-trigger>Open popover</button>
  <p>Popover content here.</p>
</Popover>`}
			svelte={`<script>
  import { Popover } from '$lib/rizzo';
</script>

<Popover>
  <button type="button" class="btn" data-popover-trigger>Open popover</button>
  <p>Popover content here.</p>
</Popover>`}
			react={reactCode}
			vue={vueCode}
			vanilla={`<!-- Rizzo CSS + popover script from package/vanilla docs. data-popover-trigger on trigger; content in popover__content. Click outside or Escape to close. -->`}
		/>
	</section>
</DocsLayout>

---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import Chart from '../../../components/astro/Chart.astro';
import FrameworkCodeTabs from '../../../components/FrameworkCodeTabs.astro';
import AddComponentTabs from '../../../components/AddComponentTabs.astro';
import { getReactCodeSnippet } from '../../../config/reactCodeSnippets';
import { getVueCodeSnippet } from '../../../config/vueCodeSnippets';
import { getAstroCodeSnippet } from '../../../config/astroCodeSnippets';
import { getSvelteCodeSnippet } from '../../../config/svelteCodeSnippets';
import { getVanillaCodeSnippet } from '../../../config/vanillaCodeSnippets';

const componentSlug = 'chart';
const reactCode = getReactCodeSnippet(componentSlug);
const vueCode = getVueCodeSnippet(componentSlug);
const astroCode = getAstroCodeSnippet(componentSlug);
const svelteCode = getSvelteCodeSnippet(componentSlug);
const vanillaCode = getVanillaCodeSnippet(componentSlug);
---

<DocsLayout title="Chart — Astro" description="Data visualization (e.g. bar chart); theme-aware; integrate with Chart.js or use CSS-only bars.">
  <section>
    <h2>Chart</h2>
    <p>Simple bar chart using theme variables. Pass a <code>data</code> array of <code>{'{ label, value }'}</code>. For complex charts, use Chart.js or Recharts with these classes.</p>
    <AddComponentTabs componentName="Chart" />
    <h3>Live Example</h3>
    <div class="example">
      <div class="example-title">Bar chart</div>
      <Chart data={[{ label: 'A', value: 40 }, { label: 'B', value: 65 }, { label: 'C', value: 30 }, { label: 'D', value: 90 }]} />
    </div>
    <h3>Usage</h3>
    <FrameworkCodeTabs astro={astroCode} svelte={svelteCode} react={reactCode} vue={vueCode} vanilla={vanillaCode} />
    <p><strong>Other frameworks:</strong> <a href="/docs/vanilla/components/chart">Vanilla</a> · <a href="/docs/svelte/components/chart">Svelte</a> · <a href="/docs/vue/components/chart">Vue</a> · <a href="/docs/react/components/chart">React</a></p>
  </section>
</DocsLayout>

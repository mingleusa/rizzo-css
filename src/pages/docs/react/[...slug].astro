---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import AddComponentTabs from '../../../components/AddComponentTabs.astro';
import FrameworkCodeTabs from '../../../components/FrameworkCodeTabs.astro';
import ReactDocDemo from '../../../components/react/ReactDocDemo';
import { getReactComponentMeta, type ReactComponentSlug } from '../../../config/reactComponents';
import { getAstroCodeSnippet } from '../../../config/astroCodeSnippets';
import { getSvelteCodeSnippet } from '../../../config/svelteCodeSnippets';
import { getReactCodeSnippet } from '../../../config/reactCodeSnippets';
import { getVueCodeSnippet } from '../../../config/vueCodeSnippets';
import { getVanillaCodeSnippet } from '../../../config/vanillaCodeSnippets';
import { getReactDocStaticPaths } from '../../../config/reactDocPaths';

export function getStaticPaths() {
  return getReactDocStaticPaths();
}

const { slug: slugParam } = Astro.params;
const slug = (slugParam as string) ?? '';
const pathParts = slug.split('/').filter(Boolean);
const componentSlug: ReactComponentSlug = (pathParts[0] === 'components' && pathParts[1] ? pathParts[1] : 'button') as ReactComponentSlug;
const meta = getReactComponentMeta(componentSlug);
const astroCode = getAstroCodeSnippet(componentSlug);
const svelteCode = getSvelteCodeSnippet(componentSlug);
const reactCode = getReactCodeSnippet(componentSlug);
const vueCode = getVueCodeSnippet(componentSlug);
const vanillaCode = getVanillaCodeSnippet(componentSlug);
---

<DocsLayout title={`${meta.title} — React`} description={meta.description}>
  <section>
    <h2>{meta.title}</h2>
    <p>{meta.description}</p>
    <p>Same BEM classes and behavior as Astro, Svelte, and Vue.</p>

    <AddComponentTabs componentName={meta.title} />

    <h3>Live examples</h3>
    <div class="example">
      <div class="example-title">React</div>
      <div class="react-doc-demo">
        <ReactDocDemo slug={componentSlug} client:load />
      </div>
    </div>

    <h3>Usage</h3>
    <FrameworkCodeTabs
      astro={astroCode}
      svelte={svelteCode}
      react={reactCode}
      vue={vueCode}
      vanilla={vanillaCode}
      defaultTab="react"
    />

    <p>
      <strong>Other frameworks:</strong>{' '}
      <a href={`/docs/components/${componentSlug}`}>Astro</a> ·{' '}
      <a href={`/docs/vanilla/components/${componentSlug}`}>Vanilla</a> ·{' '}
      <a href={`/docs/svelte/components/${componentSlug}`}>Svelte</a> ·{' '}
      <a href={`/docs/vue/components/${componentSlug}`}>Vue</a>
    </p>
  </section>
</DocsLayout>

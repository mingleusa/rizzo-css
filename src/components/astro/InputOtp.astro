---
/**
 * OTP input: multiple digit boxes. length = number of boxes (default 6).
 * Uses inline script for focus move and paste (no client:load).
 */
interface Props {
  length?: number;
  id?: string;
  /** Accessible label */
  ariaLabel?: string;
  class?: string;
}

const { length = 6, id: idProp, ariaLabel = 'One-time code', class: className = '' } = Astro.props;
const id = idProp ?? `input-otp-${Math.random().toString(36).slice(2, 9)}`;
---

<div class={`input-otp ${className}`.trim()} role="group" aria-label={ariaLabel}>
  {Array.from({ length }, (_, i) => (
    <input
      type="text"
      inputmode="numeric"
      maxlength="1"
      autocomplete="one-time-code"
      class="input-otp__digit"
      data-otp-index={i}
      data-otp-root={id}
      aria-label={`Digit ${i + 1} of ${length}`}
    />
  ))}
</div>

<script is:inline define:vars={{ length, id }}>
(function () {
  const root = document.querySelector('[data-otp-root="' + id + '"]');
  if (!root) return;
  const inputs = root.querySelectorAll('.input-otp__digit');
  function moveFocus(idx, dir) {
    const next = inputs[idx + dir];
    if (next) next.focus();
  }
  inputs.forEach(function (input, i) {
    input.addEventListener('input', function () {
      var v = this.value.replace(/\D/g, '').slice(-1);
      this.value = v;
      if (v) moveFocus(i, 1);
    });
    input.addEventListener('keydown', function (e) {
      if (e.key === 'Backspace' && !this.value) moveFocus(i, -1);
    });
    input.addEventListener('paste', function (e) {
      e.preventDefault();
      var pasted = (e.clipboardData?.getData('text') || '').replace(/\D/g, '').slice(0, length);
      pasted.split('').forEach(function (ch, j) {
        if (inputs[i + j]) { inputs[i + j].value = ch; }
      });
      var lastIdx = Math.min(i + pasted.length, length) - 1;
      if (inputs[lastIdx]) inputs[lastIdx].focus();
    });
  });
})();
</script>

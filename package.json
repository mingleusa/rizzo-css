{
  "name": "rizzo-css",
  "type": "module",
  "version": "0.0.84",
  "license": "MIT",
  "scripts": {
    "dev": "astro dev --open",
    "preview": "astro preview",
    "astro": "astro",
    "clean": "node -e \"const fs=require('fs');['dist','.astro','node_modules/.vite'].forEach(d=>{try{fs.rmSync(d,{recursive:true,force:true});console.log('Removed',d)}catch(e){}})\"",
    "build": "pnpm generate:color-formats && pnpm export:tokens && pnpm lint:css:fix && pnpm build:css && astro build",
    "build:css": "node scripts/build-css.js",
    "build:package": "pnpm lint:css:fix && pnpm build:css && pnpm copy-scaffold && pnpm prepare:vanilla-scaffold",
    "generate:color-formats": "node scripts/generate-color-formats.mjs",
    "export:tokens": "node scripts/export-tokens.mjs",
    "copy-scaffold": "node scripts/copy-scaffold.js",
    "prepare:vanilla-scaffold": "node scripts/prepare-vanilla-scaffold.js",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:css:fix": "stylelint \"src/**/*.css\" --fix",
    "test:a11y": "pnpm build && (unset NO_COLOR; FORCE_COLOR= playwright test --project=a11y)",
    "test:a11y:fast": "pnpm build && (unset NO_COLOR; FORCE_COLOR= A11Y_FAST=1 playwright test --project=a11y)",
    "test:a11y:ci": "playwright install --with-deps chromium && pnpm test:a11y",
    "test:a11y:ci:cross-browser": "pnpm build && pnpm exec playwright install --with-deps chromium firefox webkit && (unset NO_COLOR; FORCE_COLOR= pnpm exec playwright test tests/a11y --project=a11y --project=a11y-firefox --project=a11y-webkit)",
    "test:smoke": "pnpm build && (unset NO_COLOR; FORCE_COLOR= playwright test --project=smoke)",
    "test:visual": "pnpm build && (unset NO_COLOR; FORCE_COLOR= playwright test --project=visual)",
    "test:visual:update": "pnpm build && (unset NO_COLOR; FORCE_COLOR= playwright test --project=visual --update-snapshots)",
    "index:algolia": "node scripts/index-docs.js",
    "setup:algolia": "echo 'Copy .env.example to .env and add your Algolia credentials'",
    "check:contrast": "node scripts/check-contrast.mjs",
    "size": "node scripts/bundle-size.mjs",
    "check:size": "pnpm build:css && node scripts/bundle-size.mjs --check",
    "rizzo-css": "node packages/rizzo-css/bin/rizzo-css.js",
    "publish:package": "cd packages/rizzo-css && npm publish",
    "prepare": "husky",
    "storybook": "pnpm build:css && storybook dev -p 6006",
    "build-storybook": "pnpm build:css && storybook build"
  },
  "devDependencies": {
    "@astrojs/svelte": "^7.2.5",
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.49.0",
    "@storybook/addon-a11y": "^10.2.13",
    "@storybook/addon-docs": "^10.2.13",
    "@storybook/addon-links": "^10.2.13",
    "@storybook/addon-onboarding": "^10.2.13",
    "@storybook/react-vite": "^10.2.13",
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/kit": "^2.53.4",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "algoliasearch": "^5.47.0",
    "astro": "^5.17.1",
    "autoprefixer": "^10.4.23",
    "cssnano": "^7.1.2",
    "culori": "^4.0.0",
    "dotenv": "^17.2.3",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "sharp": "^0.34.5",
    "storybook": "^10.2.13",
    "stylelint": "^17.0.0",
    "stylelint-config-standard": "^40.0.0",
    "svelte": "^5.53.5",
    "svelte-check": "^4.3.6",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  },
  "author": "mingleusa",
  "dependencies": {
    "@astrojs/react": "^4.4.2",
    "@astrojs/vue": "^5.1.4",
    "fs": "0.0.1-security",
    "path": "^0.12.7",
    "postcss-js": "^5.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "style-dictionary": "^5.3.2",
    "vue": "^3.5.29"
  },
  "lint-staged": {
    "src/**/*.css": [
      "stylelint --fix"
    ]
  },
  "pnpm": {
    "overrides": {
      "rollup": "^4.59.0",
      "ajv": "^8.18.0",
      "cookie": "^0.7.0",
      "devalue": "^5.6.3",
      "svgo": ">=4.0.1",
      "flatted": ">=3.4.0"
    }
  }
}